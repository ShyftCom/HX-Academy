generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  isActive      Boolean   @default(true)
  language      String    @default("fr")
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  player        Player?
  assignedLeads      Lead[]             @relation("AssignedStaff")
  activityLogs       ActivityLog[]
  notifications      Notification[]     @relation("UserNotifications")
  agentAvailability  AgentAvailability?
  agentMeetings      Meeting[]          @relation("AgentMeetings")

  // Station relations
  stationStaff       StationStaff[]

  // Affiliate relations
  affiliate          Affiliate?         @relation("AffiliateUser")
  createdAffiliates  Affiliate[]        @relation("AffiliateCreatedBy")
  processedWithdrawals AffiliateWithdrawal[]

  // Charges
  paidCharges        Charge[]           @relation("ChargePaidBy")

  // Reviews
  reviewReplies      Review[]           @relation("ReviewReplyBy")

  // HRM
  staffProfile       StaffProfile?
  recordedAttendances Attendance[]      @relation("AttendanceRecorder")
  approvedLeaves     LeaveRequest[]     @relation("LeaveApprover")
  paidPayrolls       Payroll[]          @relation("PayrollPaidBy")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ==================== ROLES & PERMISSIONS ====================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==================== SETTINGS ====================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ==================== LEADS CRM ====================

model LeadStatus {
  id         String   @id @default(cuid())
  name       String
  color      String   @default("#6B7280")
  order      Int      @default(0)
  isDefault  Boolean  @default(false)
  isTerminal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  leads      Lead[]

  @@map("lead_statuses")
}

model Lead {
  id               String     @id @default(cuid())
  fullName         String
  phone            String?
  email            String?
  dateOfBirth      DateTime?
  age              Int?
  parentName       String?
  parentPhone      String?
  address          String?
  categoryInterest String?
  notes            String?
  source           String?
  statusId         String?
  status           LeadStatus? @relation(fields: [statusId], references: [id])
  assignedStaffId  String?
  assignedStaff    User?       @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  convertedAt      DateTime?
  isConverted      Boolean    @default(false)
  stationId        String?
  station          Station?   @relation(fields: [stationId], references: [id])
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  surveyAnswers    SurveyAnswer[]
  selectedPlanId   String?
  selectedPlan     SubscriptionPlan? @relation("ApplicationPlan", fields: [selectedPlanId], references: [id])
  applicationFiles ApplicationFile[]
  adminNotes       String?
  activities       LeadActivity[]
  meetings         Meeting[]
  leadNotes        LeadNote[]
  websiteOrders    WebsiteOrder[]

  @@map("leads")
}

model LeadActivity {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actionType      String
  description     String
  performedById   String?
  performedByName String   @default("System")
  performedByRole String   @default("system")
  metadata        Json?
  createdAt       DateTime @default(now())

  @@index([leadId])
  @@index([performedById])
  @@index([createdAt])
  @@map("lead_activities")
}

// ==================== PLAYERS ====================

model Player {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo           String?
  fullName        String
  dateOfBirth     DateTime?
  age             Int?
  gender          String?
  phone           String?
  email           String?
  parentName      String?
  parentPhone     String?
  address         String?
  emergencyContact String?
  team            String?
  category        String?
  position        String?
  medicalNotes    String?
  notes           String?
  status          String    @default("active")
  referralCode    String?
  stationId       String?
  station         Station?  @relation(fields: [stationId], references: [id])
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions      Subscription[]
  payments           Payment[]
  orders             Order[]
  notifications      Notification[]
  affiliateReferrals AffiliateReferral[]

  @@map("players")
}

// ==================== SUBSCRIPTIONS ====================

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int
  durationType String  @default("month")
  price       Float
  color       String   @default("#3B82F6")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]
  applications  Lead[]           @relation("ApplicationPlan")

  @@map("subscription_plans")
}

model Subscription {
  id        String           @id @default(cuid())
  playerId  String
  planId    String
  player    Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime?
  endDate   DateTime?
  status    String           @default("pending")
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  payments  Payment[]

  @@map("subscriptions")
}

// ==================== PAYMENTS ====================

model PaymentMethod {
  id             String   @id @default(cuid())
  name           String
  instructions   String?
  accountDetails String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       Payment[]

  @@map("payment_methods")
}

model Payment {
  id               String            @id @default(cuid())
  playerId         String
  subscriptionId   String?
  planId           String?
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  plan             SubscriptionPlan? @relation(fields: [planId], references: [id])
  paymentMethodId  String?
  paymentMethod    PaymentMethod?    @relation(fields: [paymentMethodId], references: [id])
  amount           Float
  proof            String?
  status           String            @default("pending")
  adminNotes       String?
  approvalDate     DateTime?
  rejectionReason  String?
  stationId        String?
  station          Station?          @relation(fields: [stationId], references: [id])
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("payments")
}

// ==================== STORE ====================

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  image       String?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("product_categories")
}

model Product {
  id            String          @id @default(cuid())
  name          String
  slug          String?         @unique
  description   String?
  images        String          @default("[]")
  price         Float
  discountPrice Float?
  stock         Int             @default(0)
  sku           String?         @unique
  categoryId    String?
  category      ProductCategory? @relation(fields: [categoryId], references: [id])
  status        String          @default("active")
  isFeatured    Boolean         @default(false)
  weight        Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  orderItems    OrderItem[]
  variants      ProductVariant[]
  websiteOrderItems WebsiteOrderItem[]
  reviews       Review[]

  @@map("products")
}

// ==================== COD FORM ====================

model FormField {
  id           String   @id @default(cuid())
  label        String
  fieldName    String
  fieldType    String   @default("text")
  placeholder  String?
  options      String?
  isRequired   Boolean  @default(false)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("form_fields")
}

// ==================== ORDERS ====================

model OrderStatus {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6B7280")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]

  @@map("order_statuses")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  playerId    String?
  player      Player?     @relation(fields: [playerId], references: [id])
  statusId    String?
  status      OrderStatus? @relation(fields: [statusId], references: [id])
  totalAmount Float
  codData     String      @default("{}")
  notes       String?
  stationId   String?
  station     Station?    @relation(fields: [stationId], references: [id])
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  @@map("order_items")
}

// ==================== LANDING PAGE ====================

model LandingPage {
  id          String          @id @default(cuid())
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sections    LandingSection[]

  @@map("landing_pages")
}

model LandingSection {
  id            String      @id @default(cuid())
  landingPageId String
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  type          String
  title         String?
  content       String      @default("{}")
  order         Int         @default(0)
  isEnabled     Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("landing_sections")
}

// ==================== SURVEYS ====================

model Survey {
  id          String           @id @default(cuid())
  title       String
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  questions   SurveyQuestion[]
  answers     SurveyAnswer[]

  @@map("surveys")
}

model SurveyQuestion {
  id           String   @id @default(cuid())
  surveyId     String
  survey       Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question     String
  questionType String   @default("text")
  options      String?
  isRequired   Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  answers      SurveyAnswer[]

  @@map("survey_questions")
}

model SurveyAnswer {
  id         String          @id @default(cuid())
  surveyId   String
  questionId String
  leadId     String?
  survey     Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question   SurveyQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  lead       Lead?           @relation(fields: [leadId], references: [id])
  answer     String
  createdAt  DateTime        @default(now())

  @@map("survey_answers")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  playerId  String?
  user      User?    @relation("UserNotifications", fields: [userId], references: [id])
  player    Player?  @relation(fields: [playerId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

// ==================== CALENDAR & MEETINGS ====================

model AgentAvailability {
  id             String   @id @default(cuid())
  agentId        String   @unique
  agent          User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  timezone       String   @default("Africa/Algiers")
  bufferMinutes  Int      @default(15)
  weeklySchedule Json     @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("agent_availability")
}

model Meeting {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  agentId         String
  agent           User     @relation("AgentMeetings", fields: [agentId], references: [id])
  leadName        String
  agentName       String
  date            String
  time            String
  durationMinutes Int      @default(30)
  type            String   @default("call")
  notes           String?
  status          String   @default("scheduled")
  stationId       String?
  station         Station? @relation(fields: [stationId], references: [id])
  createdById     String?
  createdByName   String   @default("System")
  reminderSent    Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([agentId, date])
  @@index([date, time, reminderSent])
  @@map("meetings")
}

model LeadNote {
  id              String   @id @default(cuid())
  leadId          String
  lead            Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  content         String
  createdById     String?
  createdByName   String   @default("System")
  createdByRole   String   @default("agent")
  createdAt       DateTime @default(now())

  @@index([leadId])
  @@map("lead_notes")
}

// ==================== ACTIVITY LOGS ====================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  module      String
  description String
  metadata    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

// ==================== MEDIA ====================

model MediaFile {
  id           String   @id @default(cuid())
  name         String
  originalName String
  url          String
  mimeType     String
  size         Int
  folder       String   @default("general")
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@map("media_files")
}

// ==================== WEBSITE / APPLICATIONS ====================

model FileRequirement {
  id           String   @id @default(cuid())
  title        String
  description  String?
  isRequired   Boolean  @default(true)
  allowedTypes String   @default("image/*,.pdf")
  maxSizeMb    Int      @default(10)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  applicationFiles ApplicationFile[]

  @@map("file_requirements")
}

model ApplicationFile {
  id            String           @id @default(cuid())
  leadId        String
  requirementId String?
  lead          Lead             @relation(fields: [leadId], references: [id], onDelete: Cascade)
  requirement   FileRequirement? @relation(fields: [requirementId], references: [id])
  fileName      String
  fileUrl       String
  mimeType      String?
  size          Int?
  createdAt     DateTime         @default(now())

  @@map("application_files")
}

// ==================== STATIONS ====================

model Station {
  id          String   @id @default(cuid())
  name        String
  wilaya      String
  wilayaCode  Int?
  address     String?
  phone       String?
  email       String?
  whatsapp    String?
  logoUrl     String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stationStaff       StationStaff[]
  leads              Lead[]
  players            Player[]
  payments           Payment[]
  orders             Order[]
  meetings           Meeting[]
  affiliates         Affiliate[]
  affiliateReferrals AffiliateReferral[]
  charges            Charge[]
  chargeCategories   ChargeCategory[]
  staffProfiles      StaffProfile[]
  payrolls           Payroll[]
  pixelConfigs       PixelConfig[]
  attributeGroups    AttributeGroup[]
  footerConfig       WebsiteFooterConfig?
  headerConfig       WebsiteHeaderConfig?
  websiteOrders      WebsiteOrder[]
  reviews            Review[]

  @@map("stations")
}

model StationStaff {
  id         String   @id @default(cuid())
  stationId  String
  station    Station  @relation(fields: [stationId], references: [id], onDelete: Cascade)
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       String?
  assignedAt DateTime @default(now())

  @@unique([stationId, userId])
  @@map("station_staff")
}

model Wilaya {
  id     String @id @default(cuid())
  code   Int    @unique
  nameFr String
  nameAr String

  @@map("wilayas")
}

// ==================== AFFILIATES ====================

model Affiliate {
  id             String   @id @default(cuid())
  userId         String   @unique
  user           User     @relation("AffiliateUser", fields: [userId], references: [id])
  stationId      String?
  station        Station? @relation(fields: [stationId], references: [id])
  code           String   @unique
  commissionRate Decimal  @default(0) @db.Decimal(5, 2)
  status         String   @default("active")
  createdById    String?
  createdBy      User?    @relation("AffiliateCreatedBy", fields: [createdById], references: [id])
  createdAt      DateTime @default(now())

  referrals    AffiliateReferral[]
  earnings     AffiliateEarning[]
  withdrawals  AffiliateWithdrawal[]

  @@map("affiliates")
}

model AffiliateReferral {
  id               String    @id @default(cuid())
  affiliateId      String
  affiliate        Affiliate @relation(fields: [affiliateId], references: [id])
  playerId         String
  player           Player    @relation(fields: [playerId], references: [id])
  registrationDate DateTime  @default(now())
  paymentStatus    String    @default("unpaid")
  amountPaid       Decimal   @default(0) @db.Decimal(10, 2)
  paidAt           DateTime?
  stationId        String?
  station          Station?  @relation(fields: [stationId], references: [id])

  earnings AffiliateEarning[]

  @@map("affiliate_referrals")
}

model AffiliateEarning {
  id          String            @id @default(cuid())
  affiliateId String
  affiliate   Affiliate         @relation(fields: [affiliateId], references: [id])
  referralId  String
  referral    AffiliateReferral @relation(fields: [referralId], references: [id])
  amount      Decimal           @db.Decimal(10, 2)
  status      String            @default("pending")
  createdAt   DateTime          @default(now())

  @@map("affiliate_earnings")
}

model AffiliateWithdrawal {
  id             String    @id @default(cuid())
  affiliateId    String
  affiliate      Affiliate @relation(fields: [affiliateId], references: [id])
  amount         Decimal   @db.Decimal(10, 2)
  status         String    @default("pending")
  requestedAt    DateTime  @default(now())
  processedAt    DateTime?
  processedById  String?
  processedBy    User?     @relation(fields: [processedById], references: [id])
  notes          String?

  @@map("affiliate_withdrawals")
}

// ==================== CHARGES ====================

model ChargeCategory {
  id        String   @id @default(cuid())
  name      String
  stationId String?
  station   Station? @relation(fields: [stationId], references: [id])
  color     String?
  isGlobal  Boolean  @default(false)

  charges   Charge[]

  @@map("charge_categories")
}

model Charge {
  id         String          @id @default(cuid())
  stationId  String?
  station    Station?        @relation(fields: [stationId], references: [id])
  categoryId String?
  category   ChargeCategory? @relation(fields: [categoryId], references: [id])
  title      String
  amount     Decimal         @db.Decimal(10, 2)
  chargeDate DateTime
  paidById   String?
  paidBy     User?           @relation("ChargePaidBy", fields: [paidById], references: [id])
  receiptUrl String?
  notes      String?
  isSalary   Boolean         @default(false)
  staffId    String?
  staff      StaffProfile?   @relation(fields: [staffId], references: [id])
  createdAt  DateTime        @default(now())

  @@map("charges")
}

// ==================== HRM ====================

model StaffProfile {
  id          String    @id @default(cuid())
  userId      String    @unique
  user        User      @relation(fields: [userId], references: [id])
  stationId   String?
  station     Station?  @relation(fields: [stationId], references: [id])
  fullName    String
  role        String?
  phone       String?
  nationalId  String?
  hireDate    DateTime?
  baseSalary  Decimal?  @db.Decimal(10, 2)
  salaryType  String    @default("monthly")
  bankAccount String?
  status      String    @default("active")

  attendances   Attendance[]
  leaveRequests LeaveRequest[]
  payrolls      Payroll[]
  charges       Charge[]

  @@map("staff_profiles")
}

model Attendance {
  id           String       @id @default(cuid())
  staffId      String
  staff        StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  date         DateTime
  status       String
  checkIn      String?
  checkOut     String?
  notes        String?
  recordedById String?
  recordedBy   User?        @relation("AttendanceRecorder", fields: [recordedById], references: [id])

  @@unique([staffId, date])
  @@map("attendance")
}

model LeaveRequest {
  id           String       @id @default(cuid())
  staffId      String
  staff        StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  leaveType    String
  startDate    DateTime
  endDate      DateTime
  daysCount    Int
  reason       String?
  status       String       @default("pending")
  approvedById String?
  approvedBy   User?        @relation("LeaveApprover", fields: [approvedById], references: [id])
  createdAt    DateTime     @default(now())

  @@map("leave_requests")
}

model Payroll {
  id                String       @id @default(cuid())
  staffId           String
  staff             StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  stationId         String?
  station           Station?     @relation(fields: [stationId], references: [id])
  month             Int
  year              Int
  baseSalary        Decimal      @db.Decimal(10, 2)
  bonuses           Decimal      @default(0) @db.Decimal(10, 2)
  deductions        Decimal      @default(0) @db.Decimal(10, 2)
  absencesDeduction Decimal      @default(0) @db.Decimal(10, 2)
  netSalary         Decimal      @db.Decimal(10, 2)
  status            String       @default("unpaid")
  paidAt            DateTime?
  paidById          String?
  paidBy            User?        @relation("PayrollPaidBy", fields: [paidById], references: [id])
  notes             String?

  @@unique([staffId, month, year])
  @@map("payroll")
}

// ==================== PRODUCT VARIANTS ====================

model AttributeGroup {
  id        String   @id @default(cuid())
  name      String
  stationId String?
  station   Station? @relation(fields: [stationId], references: [id])

  attributes Attribute[]

  @@map("attribute_groups")
}

model Attribute {
  id       String         @id @default(cuid())
  groupId  String
  group    AttributeGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  value    String
  colorHex String?

  variantAttributes VariantAttribute[]

  @@map("attributes")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  sku       String?
  price     Decimal? @db.Decimal(10, 2)
  stock     Int      @default(0)
  imageUrl  String?
  isActive  Boolean  @default(true)

  variantAttributes VariantAttribute[]

  @@map("product_variants")
}

model VariantAttribute {
  variantId   String
  attributeId String
  variant     ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  attribute   Attribute      @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@id([variantId, attributeId])
  @@map("variant_attributes")
}

// ==================== PIXELS ====================

model PixelConfig {
  id               String   @id @default(cuid())
  stationId        String?
  station          Station? @relation(fields: [stationId], references: [id])
  platform         String
  pixelId          String?
  accessToken      String?
  useConversionApi Boolean  @default(false)
  testEventCode    String?
  isActive         Boolean  @default(true)
  updatedAt        DateTime @updatedAt

  @@unique([stationId, platform])
  @@map("pixel_configs")
}

// ==================== WEBSITE FOOTER ====================

model WebsiteFooterConfig {
  id              String   @id @default(cuid())
  stationId       String?  @unique
  station         Station? @relation(fields: [stationId], references: [id])
  backgroundColor String   @default("#0a1628")
  textColor       String   @default("#ffffff")
  accentColor     String   @default("#1da1f2")
  logoUrl         String?
  tagline         String?
  taglineFr       String?
  taglineAr       String?
  copyrightText   String   @default("© 2026 Football Skills Academy. All rights reserved.")
  showTrustpilot  Boolean  @default(false)
  trustpilotUrl   String?
  updatedAt       DateTime @updatedAt

  linkColumns     FooterLinkColumn[]
  socialLinks     FooterSocialLink[]
  bottomLinks     FooterBottomLink[]

  @@map("website_footer_configs")
}

model FooterLinkColumn {
  id       String              @id @default(cuid())
  footerId String
  footer   WebsiteFooterConfig @relation(fields: [footerId], references: [id], onDelete: Cascade)
  title    String
  titleFr  String?
  titleAr  String?
  position Int                 @default(0)

  links    FooterLink[]

  @@map("footer_link_columns")
}

model FooterLink {
  id           String           @id @default(cuid())
  columnId     String
  column       FooterLinkColumn @relation(fields: [columnId], references: [id], onDelete: Cascade)
  label        String
  labelFr      String?
  labelAr      String?
  url          String
  openInNewTab Boolean          @default(false)
  position     Int              @default(0)
  isActive     Boolean          @default(true)

  @@map("footer_links")
}

model FooterSocialLink {
  id       String              @id @default(cuid())
  footerId String
  footer   WebsiteFooterConfig @relation(fields: [footerId], references: [id], onDelete: Cascade)
  platform String
  url      String
  isActive Boolean             @default(true)
  position Int                 @default(0)

  @@map("footer_social_links")
}

model FooterBottomLink {
  id       String              @id @default(cuid())
  footerId String
  footer   WebsiteFooterConfig @relation(fields: [footerId], references: [id], onDelete: Cascade)
  label    String
  labelFr  String?
  labelAr  String?
  url      String
  position Int                 @default(0)

  @@map("footer_bottom_links")
}

// ==================== WEBSITE HEADER ====================

model WebsiteHeaderConfig {
  id                   String   @id @default(cuid())
  stationId            String?  @unique
  station              Station? @relation(fields: [stationId], references: [id])
  logoUrl              String?
  backgroundColor      String   @default("#ffffff")
  textColor            String   @default("#0a1628")
  accentColor          String   @default("#0a1628")
  sticky               Boolean  @default(true)
  showLanguageSwitcher Boolean  @default(true)
  ctaLabel             String?
  ctaLabelFr           String?
  ctaLabelAr           String?
  ctaUrl               String?
  ctaStyle             String   @default("filled")
  updatedAt            DateTime @updatedAt

  navItems             HeaderNavItem[]

  @@map("website_header_configs")
}

model HeaderNavItem {
  id           String              @id @default(cuid())
  headerId     String
  header       WebsiteHeaderConfig @relation(fields: [headerId], references: [id], onDelete: Cascade)
  label        String
  labelFr      String?
  labelAr      String?
  url          String?
  hasDropdown  Boolean             @default(false)
  position     Int                 @default(0)
  isActive     Boolean             @default(true)

  dropdownItems HeaderNavDropdownItem[]

  @@map("header_nav_items")
}

model HeaderNavDropdownItem {
  id            String        @id @default(cuid())
  navItemId     String
  navItem       HeaderNavItem @relation(fields: [navItemId], references: [id], onDelete: Cascade)
  label         String
  labelFr       String?
  labelAr       String?
  url           String
  icon          String?
  description   String?
  descriptionFr String?
  descriptionAr String?
  position      Int           @default(0)
  isActive      Boolean       @default(true)

  @@map("header_nav_dropdown_items")
}

// ==================== WEBSITE STORE ORDERS ====================

model WebsiteOrder {
  id            String    @id @default(cuid())
  orderNumber   String    @unique
  stationId     String?
  station       Station?  @relation(fields: [stationId], references: [id])
  customerName  String
  customerPhone String
  customerEmail String?
  wilaya        String?
  city          String?
  address       String?
  deliveryNotes String?
  subtotal      Decimal   @db.Decimal(10, 2)
  shippingFee   Decimal   @default(0) @db.Decimal(10, 2)
  total         Decimal   @db.Decimal(10, 2)
  status        String    @default("pending")
  leadId        String?
  lead          Lead?     @relation(fields: [leadId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  items         WebsiteOrderItem[]

  @@map("website_orders")
}

model WebsiteOrderItem {
  id        String       @id @default(cuid())
  orderId   String
  order     WebsiteOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product      @relation(fields: [productId], references: [id])
  variantId String?
  variantInfo String?
  quantity  Int
  price     Decimal      @db.Decimal(10, 2)

  @@map("website_order_items")
}

// ==================== REVIEWS ====================

model Review {
  id            String    @id @default(cuid())
  stationId     String?
  station       Station?  @relation(fields: [stationId], references: [id])
  reviewerName  String
  reviewerEmail String?
  reviewerPhone String?
  rating        Int
  title         String?
  content       String
  productId     String?
  product       Product?  @relation(fields: [productId], references: [id])
  orderId       String?
  status        String    @default("pending")
  isVerified    Boolean   @default(false)
  isFeatured    Boolean   @default(false)
  adminReply    String?
  adminReplyAt  DateTime?
  adminReplyBy  String?
  adminReplier  User?     @relation("ReviewReplyBy", fields: [adminReplyBy], references: [id])
  createdAt     DateTime  @default(now())

  @@map("reviews")
}
