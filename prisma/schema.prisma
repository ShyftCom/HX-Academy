generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== AUTH ====================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  password      String?
  roleId        String?
  role          Role?     @relation(fields: [roleId], references: [id])
  isActive      Boolean   @default(true)
  lastLogin     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]
  player        Player?
  assignedLeads Lead[]    @relation("AssignedStaff")
  activityLogs  ActivityLog[]
  notifications Notification[] @relation("UserNotifications")

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  createdAt DateTime @default(now())

  @@map("password_reset_tokens")
}

// ==================== ROLES & PERMISSIONS ====================

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  module      String
  action      String
  createdAt   DateTime @default(now())

  roles       RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@map("role_permissions")
}

// ==================== SETTINGS ====================

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  type      String   @default("string")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("settings")
}

// ==================== LEADS CRM ====================

model LeadStatus {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6B7280")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  leads     Lead[]

  @@map("lead_statuses")
}

model Lead {
  id               String     @id @default(cuid())
  fullName         String
  phone            String?
  email            String?
  dateOfBirth      DateTime?
  age              Int?
  parentName       String?
  parentPhone      String?
  address          String?
  categoryInterest String?
  notes            String?
  source           String?
  statusId         String?
  status           LeadStatus? @relation(fields: [statusId], references: [id])
  assignedStaffId  String?
  assignedStaff    User?       @relation("AssignedStaff", fields: [assignedStaffId], references: [id])
  convertedAt      DateTime?
  isConverted      Boolean    @default(false)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  surveyAnswers    SurveyAnswer[]

  @@map("leads")
}

// ==================== PLAYERS ====================

model Player {
  id              String    @id @default(cuid())
  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  photo           String?
  fullName        String
  dateOfBirth     DateTime?
  age             Int?
  gender          String?
  phone           String?
  email           String?
  parentName      String?
  parentPhone     String?
  address         String?
  emergencyContact String?
  team            String?
  category        String?
  position        String?
  medicalNotes    String?
  notes           String?
  status          String    @default("active")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  subscriptions   Subscription[]
  payments        Payment[]
  orders          Order[]
  notifications   Notification[]

  @@map("players")
}

// ==================== SUBSCRIPTIONS ====================

model SubscriptionPlan {
  id          String   @id @default(cuid())
  name        String
  description String?
  duration    Int
  durationType String  @default("month")
  price       Float
  color       String   @default("#3B82F6")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  subscriptions Subscription[]
  payments      Payment[]

  @@map("subscription_plans")
}

model Subscription {
  id        String           @id @default(cuid())
  playerId  String
  planId    String
  player    Player           @relation(fields: [playerId], references: [id], onDelete: Cascade)
  plan      SubscriptionPlan @relation(fields: [planId], references: [id])
  startDate DateTime?
  endDate   DateTime?
  status    String           @default("pending")
  notes     String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  payments  Payment[]

  @@map("subscriptions")
}

// ==================== PAYMENTS ====================

model PaymentMethod {
  id             String   @id @default(cuid())
  name           String
  instructions   String?
  accountDetails String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  payments       Payment[]

  @@map("payment_methods")
}

model Payment {
  id               String            @id @default(cuid())
  playerId         String
  subscriptionId   String?
  planId           String?
  player           Player            @relation(fields: [playerId], references: [id], onDelete: Cascade)
  subscription     Subscription?     @relation(fields: [subscriptionId], references: [id])
  plan             SubscriptionPlan? @relation(fields: [planId], references: [id])
  paymentMethodId  String?
  paymentMethod    PaymentMethod?    @relation(fields: [paymentMethodId], references: [id])
  amount           Float
  proof            String?
  status           String            @default("pending")
  adminNotes       String?
  approvalDate     DateTime?
  rejectionReason  String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  @@map("payments")
}

// ==================== STORE ====================

model ProductCategory {
  id          String    @id @default(cuid())
  name        String
  description String?
  image       String?
  isActive    Boolean   @default(true)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@map("product_categories")
}

model Product {
  id            String          @id @default(cuid())
  name          String
  description   String?
  images        String          @default("[]")
  price         Float
  discountPrice Float?
  stock         Int             @default(0)
  sku           String?         @unique
  categoryId    String?
  category      ProductCategory? @relation(fields: [categoryId], references: [id])
  status        String          @default("active")
  isFeatured    Boolean         @default(false)
  weight        Float?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  orderItems    OrderItem[]

  @@map("products")
}

// ==================== COD FORM ====================

model FormField {
  id           String   @id @default(cuid())
  label        String
  fieldName    String
  fieldType    String   @default("text")
  placeholder  String?
  options      String?
  isRequired   Boolean  @default(false)
  isDefault    Boolean  @default(false)
  isActive     Boolean  @default(true)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("form_fields")
}

// ==================== ORDERS ====================

model OrderStatus {
  id        String   @id @default(cuid())
  name      String
  color     String   @default("#6B7280")
  order     Int      @default(0)
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders    Order[]

  @@map("order_statuses")
}

model Order {
  id          String      @id @default(cuid())
  orderNumber String      @unique
  playerId    String?
  player      Player?     @relation(fields: [playerId], references: [id])
  statusId    String?
  status      OrderStatus? @relation(fields: [statusId], references: [id])
  totalAmount Float
  codData     String      @default("{}")
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  items       OrderItem[]

  @@map("orders")
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float
  createdAt DateTime @default(now())

  @@map("order_items")
}

// ==================== LANDING PAGE ====================

model LandingPage {
  id          String          @id @default(cuid())
  isPublished Boolean         @default(false)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  sections    LandingSection[]

  @@map("landing_pages")
}

model LandingSection {
  id            String      @id @default(cuid())
  landingPageId String
  landingPage   LandingPage @relation(fields: [landingPageId], references: [id], onDelete: Cascade)
  type          String
  title         String?
  content       String      @default("{}")
  order         Int         @default(0)
  isEnabled     Boolean     @default(true)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@map("landing_sections")
}

// ==================== SURVEYS ====================

model Survey {
  id          String           @id @default(cuid())
  title       String
  description String?
  isActive    Boolean          @default(true)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  questions   SurveyQuestion[]
  answers     SurveyAnswer[]

  @@map("surveys")
}

model SurveyQuestion {
  id           String   @id @default(cuid())
  surveyId     String
  survey       Survey   @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question     String
  questionType String   @default("text")
  options      String?
  isRequired   Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  answers      SurveyAnswer[]

  @@map("survey_questions")
}

model SurveyAnswer {
  id         String          @id @default(cuid())
  surveyId   String
  questionId String
  leadId     String?
  survey     Survey          @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  question   SurveyQuestion  @relation(fields: [questionId], references: [id], onDelete: Cascade)
  lead       Lead?           @relation(fields: [leadId], references: [id])
  answer     String
  createdAt  DateTime        @default(now())

  @@map("survey_answers")
}

// ==================== NOTIFICATIONS ====================

model Notification {
  id        String   @id @default(cuid())
  userId    String?
  playerId  String?
  user      User?    @relation("UserNotifications", fields: [userId], references: [id])
  player    Player?  @relation(fields: [playerId], references: [id])
  title     String
  message   String
  type      String   @default("info")
  isRead    Boolean  @default(false)
  link      String?
  createdAt DateTime @default(now())

  @@map("notifications")
}

// ==================== ACTIVITY LOGS ====================

model ActivityLog {
  id          String   @id @default(cuid())
  userId      String?
  user        User?    @relation(fields: [userId], references: [id])
  action      String
  module      String
  description String
  metadata    String?
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@map("activity_logs")
}

// ==================== MEDIA ====================

model MediaFile {
  id           String   @id @default(cuid())
  name         String
  originalName String
  url          String
  mimeType     String
  size         Int
  folder       String   @default("general")
  uploadedBy   String?
  createdAt    DateTime @default(now())

  @@map("media_files")
}
